    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript-eslint-language-service": "^5.0.5"
  }
